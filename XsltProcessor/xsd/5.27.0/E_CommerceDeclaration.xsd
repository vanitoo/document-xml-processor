<?xml version="1.0" encoding="UTF-8"?>
<!-- Решение Коллегии ЕЭК от 17.12.2024 № 143 "О декларации на товары электронной торговли"-->
<!-- Решение Коллегии ЕЭК от 17.12.2024 № 144 "О структуре и формате декларации на товары электронной торговли" -->
<!-- Решение Коллегии ЕЭК от ДД.ММ.20ГГ № ХХХ "О внесении изменений в Решение Коллегии Евразийской экономической комиссии от 17 декабря 2024 г. № 144" -->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:clt_ru="urn:customs.ru:CommonLeafTypes:5.10.0" xmlns:cat_ru="urn:customs.ru:CommonAggregateTypes:5.24.0" xmlns:RUSclt_ru="urn:customs.ru:RUSCommonLeafTypes:5.21.0" xmlns:RUScat_ru="urn:customs.ru:RUSCommonAggregateTypes:5.24.0" xmlns:RUDECLcat="urn:customs.ru:RUDeclCommonAggregateTypesCust:5.27.0" xmlns:cltESAD_cu="urn:customs.ru:CUESADCommonLeafTypes:5.17.0" xmlns:catESAD_cu="urn:customs.ru:CUESADCommonAggregateTypesCust:5.27.0" xmlns:e_cd="urn:customs.ru:Information:CustomsDocuments:E_CommerceDeclaration:5.27.0" targetNamespace="urn:customs.ru:Information:CustomsDocuments:E_CommerceDeclaration:5.27.0" elementFormDefault="qualified" version="5.27.0.0">
	<xs:import namespace="urn:customs.ru:CommonAggregateTypes:5.24.0" schemaLocation="CommonAggregateTypesCust.xsd"/>
	<xs:import namespace="urn:customs.ru:CommonLeafTypes:5.10.0" schemaLocation="CommonLeafTypesCust.xsd"/>
	<xs:import namespace="urn:customs.ru:RUSCommonLeafTypes:5.21.0" schemaLocation="RUSCommonLeafTypes.xsd"/>
	<xs:import namespace="urn:customs.ru:RUSCommonAggregateTypes:5.24.0" schemaLocation="RUSCommonAggregateTypes.xsd"/>
	<xs:import namespace="urn:customs.ru:RUDeclCommonAggregateTypesCust:5.27.0" schemaLocation="RUDeclCommonAggregateTypesCust.xsd"/>
	<xs:import namespace="urn:customs.ru:CUESADCommonLeafTypes:5.17.0" schemaLocation="CUESADCommonLeafTypesCust.xsd"/>
	<xs:import namespace="urn:customs.ru:CUESADCommonAggregateTypesCust:5.27.0" schemaLocation="CUESADCommonAggregateTypesCust.xsd"/>
	<xs:annotation>
		<xs:documentation>Декларация на товары электронной торговли</xs:documentation>
	</xs:annotation>
	<xs:element name="E_CommerceDeclaration" type="e_cd:E_CommerceDeclarationType">
		<xs:annotation>
			<xs:documentation>Декларация на товары электронной торговли</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="E_CommerceDeclarationType">
		<xs:annotation>
			<xs:documentation>Декларация на товары электронной торговли</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="cat_ru:BaseDocType">
				<xs:sequence>
					<xs:element name="EECEDocHeaderAddInfo" type="RUScat_ru:EECEDocHeaderAddInfoType">
						<xs:annotation>
							<xs:documentation>Дополнительные технологические реквизиты электронного документа (сведений)</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="RefDeclarationIdDetails" type="e_cd:RefDeclarationIdDetailsType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Регистрационный номер декларации на товары электронной торговли, сведения в которой изменяются (дополняются)</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="DeclarationKindCode" type="clt_ru:CUCustomsProcedureType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Кодовое обозначение типа таможенной декларации </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="CustomsModeCode" type="cltESAD_cu:CustomsModeCodeType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Кодовое обозначение вида заявляемой таможенной процедуры</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="PreviousCustomsModeCode" type="cltESAD_cu:CustomsModeCodeType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Кодовое обозначение вида предшествующей таможенной процедуры </xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="DeclarationKind" type="cltESAD_cu:CustomsDeclarationKindType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Кодовое обозначение особенности таможенного декларирования товаров</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="ElectronicDocumentSign" type="clt_ru:Code2Type">
						<xs:annotation>
							<xs:documentation>Признак электронного документа "ЭД"</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="TotalSheetNumber" type="clt_ru:Count4Type" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Общее количество листов в документе</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="GoodsCategoryCode" type="clt_ru:Code2Type">
						<xs:annotation>
							<xs:documentation>Кодовое обозначение категории товаров электронной торговли: "ЭФ" - товары, приобретенные физическими лицами; "ЭС" - товары, предназначенные для реализации физическим лицам</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="GoodsShipment" type="e_cd:GoodsShipmentType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Сведения о товарной партии</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="EventDate" type="clt_ru:DateCustType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Дата заполнения таможенного документа</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="DeclarantDetails" type="RUDECLcat:AEODeclarantDetailsType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Сведения о лице, осуществляющем таможенное декларирование товаров электронной торговли</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="SignatoryPerson" type="e_cd:SignatoryPersonDetailsType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Сведения о сотруднике лица, осуществляющего таможенное декларирование товаров электронной торговли и (или) заполнившего таможенный документ</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
				<xs:attribute name="DocumentModeID" type="clt_ru:DocumentModeIDType" use="required" fixed="1006295E">
					<xs:annotation>
						<xs:documentation>Идентификатор вида документа</xs:documentation>
					</xs:annotation>
				</xs:attribute>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:annotation>
		<xs:documentation>Локальные прикладные типы</xs:documentation>
	</xs:annotation>
	<xs:complexType name="AutomobileInfoType">
		<xs:annotation>
			<xs:documentation>Сведения об автомобиле</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="VINID" type="clt_ru:VINIDType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификационный номер транспортного средства (шасси транспортного средства, самоходной машины), присвоенный изготовителем</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VINChassisID" type="clt_ru:VINIDType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификационный номер шасси (рамы) транспортного средства, присвоенный изготовителем</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VINBodyID" type="clt_ru:VINIDType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификационный номер кузова (кабины) транспортного средства (шасси транспортного средства, самоходной машины), присвоенный изготовителем</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="MarkCode" type="clt_ru:MarkCarCodeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение марки транспортного средства </xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Mark" type="clt_ru:MarkCarNameType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Наименование марки транспортного средства (шасси транспортного средства, самоходной машины)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Model" type="clt_ru:TransportNameType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Наименование модели транспортного средства</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ManufactureDate" type="clt_ru:DateCustType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Дата изготовления (момент выпуска) транспортного средства</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VehicleEngineDetails" type="e_cd:EngineType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Сведения о двигателе</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ECOClassCode" type="clt_ru:LetterIndicatorType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение экологического класса транспортного средства (шасси транспортного средства), присвоенное организацией-изготовителем</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VehicleAxleQuantity" type="clt_ru:Count2Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Количество осей транспортного средства (шасси транспортного средства, самоходной машины и других видов техники)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VehicleMassDetails" type="e_cd:VehicleMassDetailsType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Сведения о массе транспортного средства (шасси транспортного средства, самоходной машины или другого вида техники)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TransportCategoryCode" type="clt_ru:CodeVariable3Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение категории транспортного средства (шасси транспортного средства, самоходной машины и других видов техники)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TransportCarryingCapacityMeasure" type="catESAD_cu:UnifiedPhysicalMeasureType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Масса груза, на перевозку которого рассчитано данное транспортное средство</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VehicleWheelbaseMeasure" type="catESAD_cu:UnifiedPhysicalMeasureType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Колесная база транспортного средства</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VehicleModificationText" type="RUSclt_ru:FreeText4000Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Модификация транспортного средства</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CapacityQuantity" type="clt_ru:Quantity5Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Количество мест для сидения</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PlatformLengthMeasure" type="catESAD_cu:UnifiedPhysicalMeasureType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Максимальная внутренняя длина площадки для перевозки грузов (грузовой платформы)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VehicleMileageMeasure" type="catESAD_cu:UnifiedPhysicalMeasureType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Пробег транспортного средства</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CAValueAmount" type="catESAD_cu:CarCostInfoType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Стоимость</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EmergencyDeviceId" type="clt_ru:Text50Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификационный номер устройства вызова экстренных служб</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CalculationType">
		<xs:annotation>
			<xs:documentation>Сведения об исчислении платежа</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="RUDECLcat:CalculationType">
				<xs:sequence>
					<xs:element name="FractionRefinanceRate" type="clt_ru:QuantityBasis0Type" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Доля ставки рефинансирования (ключевой ставки)</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="CommodityDescriptionDetailsType">
		<xs:annotation>
			<xs:documentation>Дополнительные сведения о товаре</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="RecordId" type="clt_ru:Text40Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификатор записи</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TradeMarkName" type="clt_ru:FreeText250Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Наименование товарного знака, объекта авторского права, смежных прав, патента  и т.д. </xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ProductionPlaceName" type="clt_ru:FreeText250Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Наименование места происхождения</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ProductMarkName" type="clt_ru:FreeText250Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Наименование марки</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ProductModelName" type="clt_ru:FreeText250Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Наименование модели продукта (товара)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ProductId" type="cltESAD_cu:GoodsArticulType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Уникальный идентификатор вида продукта (товара) или артикул товара</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ProductSortName" type="clt_ru:FreeText250Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Наименование сорта (группы сортов) продукта (товара)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="StandardName" type="clt_ru:Text40Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Наименование стандарта (международного, межгосударственного, государственного, отраслевого или организации) или технических условий на товар </xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ProductInstanceId" type="clt_ru:Text50Type" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Уникальный идентификатор (серийный номер, код) экземпляра продукта (товара)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ManufactureDate" type="clt_ru:DateCustType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Дата производства (изготовления) товара</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CommodityGroupItemDetailsType">
		<xs:annotation>
			<xs:documentation>Характеристика товаров в группе</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="LineId" type="clt_ru:Text40Type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификатор записи</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CommodityDescriptionDetails" type="e_cd:CommodityDescriptionDetailsType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Дополнительные сведения о товаре</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ManufacturerDetails" type="e_cd:ManufacturerDetailsType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Сведения о производителе (изготовителе)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="UnifiedOverallDimensionDetails" type="catESAD_cu:DimensionType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Линейные размеры объекта (длина, ширина и высота)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="GoodsMeasureDetails" type="catESAD_cu:SupplementaryQuantityType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Количество товаров</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DrugStartingMaterialDetails" type="catESAD_cu:DrugStartingMaterialDetailsType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Сведения об идентификации исходного материала для производства лекарственных препаратов</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CurrencyValueType">
		<xs:annotation>
			<xs:documentation>Сведения о стоимости</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="CurrencyQuantity" type="clt_ru:AmountType">
				<xs:annotation>
					<xs:documentation>Сумма в валюте</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CurrencyCode" type="clt_ru:CurrencyA3CodeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Буквенный код валюты </xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="DeclarationChangeCodeDetailsType">
		<xs:annotation>
			<xs:documentation>Сведения о внесенных изменениях (дополнениях)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StageChangeCode" type="clt_ru:LetterIndicatorType">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение этапа внесения изменений (дополнений) в сведения, заявленные в таможенной декларации</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ReasonChangeCode" type="clt_ru:LetterIndicatorType">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение обстоятельств, послуживших основанием для внесения изменений (дополнений) в сведения, заявленные в таможенной декларации</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="QuantityChangeCode" type="clt_ru:LetterIndicatorType">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение изменения (дополнения) сведений, заявленных в таможенной декларации, о количестве (массе) товаров</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CountryChangeCode" type="clt_ru:LetterIndicatorType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение изменения (дополнения) сведений, заявленных в таможенной декларации, о происхождении товаров и (или) тарифных преференциях</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TNVEDChangeCode" type="clt_ru:LetterIndicatorType">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение изменения кода товара в соответствии с ТН ВЭД ЕАЭС</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CustomsCostChangeCode" type="clt_ru:LetterIndicatorType">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение изменения (дополнения) сведений, заявленных в таможенной декларации, о таможенной стоимости (стоимости) товаров</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CustomsPaymentChangeCode" type="clt_ru:LetterIndicatorType">
				<xs:annotation>
					<xs:documentation>Кодовое обозначение изменения (дополнения) сведений, заявленных в таможенной декларации, об исчислении (уплате) таможенных и иных платежей (влекущих изменение (дополнение) сведений об исчислении таможенных и иных платежей)</xs:documentation>
				</xs:annotation>
			</xs:element>
