{
  "id": null,
  "uid": "docker-logs",
  "title": "Docker Logs",
  "tags": [
    "docker",
    "loki",
    "logs"
  ],
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "label": "Host",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "definition": "label_values(host)",
        "query": {
          "type": 1,
          "label": "host",
          "stream": ""
        },
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "project",
        "type": "query",
        "label": "Project",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "definition": "label_values(compose_project)",
        "query": {
          "type": 1,
          "label": "compose_project",
          "stream": ""
        },
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "definition": "label_values(compose_service)",
        "query": {
          "type": 1,
          "label": "compose_service",
          "stream": ""
        },
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "definition": "label_values(container)",
        "query": {
          "type": 1,
          "label": "container",
          "stream": ""
        },
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "query",
        "type": "textbox",
        "label": "Query",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log entries",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "range",
          "editorMode": "code",
          "expr": "sum(count_over_time({host=~\"$host\", compose_project=~\"$project\", compose_service=~\"$service\", container=~\"$container\"} |= \"$query\" [$__interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "title": "Docker logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "range",
          "editorMode": "code",
          "expr": "{host=~\"$host\", compose_project=~\"$project\", compose_service=~\"$service\", container=~\"$container\"} |= \"$query\""
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "exact",
        "enableInfiniteScrolling": true
      }
    },
    {
      "id": 3,
      "title": "Top noisy containers (5m)",
      "type": "bargauge",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "range",
          "editorMode": "code",
          "expr": "topk(10, sum by (container) (count_over_time({compose_project=~\"$project\"} [5m])))"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "id": 4,
      "title": "Errors by container (15m)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "range",
          "editorMode": "code",
          "expr": "sum by (container) (count_over_time({compose_project=~\"$project\"} |~ \"(?i)error|exception|failed|traceback|critical\" [15m]))"
        }
      ]
    }
  ]
}